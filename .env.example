# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nibbler

# ── Claude API ────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL_FREE=claude-haiku-4-5
CLAUDE_MODEL_PAID=claude-sonnet-4-6

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_CLIENT_ID=your-client-id

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-north-1
S3_BUCKET_NAME=nibbler-user-files

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=nibbler-content
PINECONE_ENVIRONMENT=gcp-starter

# ── Voyage AI (embeddings) ────────────────────────────────────────────────────
# Without a key, embeddings fall back to a deterministic mock (dev only)
VOYAGE_API_KEY=

# ── RevenueCat (subscription sync) ────────────────────────────────────────────
# Webhook secret: the Authorization header value you set in the RC dashboard
# webhook config. Secret API key: RC dashboard → API keys → secret (sk_...).
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_SECRET_API_KEY=

# ── Push Notifications (Expo) ─────────────────────────────────────────────────
# Optional: get from expo.dev → Project → Access Tokens (increases rate limits)
EXPO_ACCESS_TOKEN=

# ── Analytics (Mixpanel) ──────────────────────────────────────────────────────
# Same project token as frontend — mixpanel.com → Project → Settings
MIXPANEL_TOKEN=

# ── Support (bug reports + email) ─────────────────────────────────────────────
# Same Resend account the website contact form uses
RESEND_API_KEY=
SUPPORT_FROM_EMAIL=noreply@getnibbler.com
BUG_REPORT_EMAIL=bug-report@getnibbler.com
BUG_DRIVE_FOLDER_ID=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars
FREE_UPLOAD_LIMIT=3
FREE_BITES_PER_DAY=1
PREMIUM_BITES_PER_DAY=3
